msgstr ""
"Drag a line from the Output Port of Node 1 (small square on the right) to "
"the Input Port of Node 2 (on the left)"

msgid "ขั้นตอนที่ 3: ตั้งค่า"
msgstr "Step 3: Configure"

msgid "คลิกขวาที่ Node กด configure แล้วใส่ SQL Query:"
msgstr "Right-click the Node, select configure, and enter SQL Query:"

